    {
      "type": "text",
      "id": "why_header",
      "x": 80,
      "y": 482,
      "width": 1040,
      "height": 24,
      "text": "Why cdp-proxy exists",
      "originalText": "Why cdp-proxy exists",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#b45309",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
