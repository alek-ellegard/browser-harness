    },
    {
      "type": "text",
      "id": "why_text",
      "x": 80,
      "y": 510,
      "width": 1040,
      "height": 50,
      "text": "Chrome M111+ rejects /json/* unless Host: localhost (DNS-rebinding guard).  Cross-container Host: chrome:9222 → HTTP 500.\nnginx rewrites Host → localhost  +  sub_filter rewrites webSocketDebuggerUrl on /json/* responses.   Use BU_CDP_URL, not BU_CDP_WS  (which bypasses /json/*).",
      "originalText": "Chrome M111+ rejects /json/* unless Host: localhost (DNS-rebinding guard).  Cross-container Host: chrome:9222 → HTTP 500.\nnginx rewrites Host → localhost  +  sub_filter rewrites webSocketDebuggerUrl on /json/* responses.   Use BU_CDP_URL, not BU_CDP_WS  (which bypasses /json/*).",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 450005,
      "version": 1,
      "versionNonce": 450006,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.5
    },

